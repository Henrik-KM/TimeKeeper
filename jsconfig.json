{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": true,
    "allowJs": true,
    "noEmit": true,
    "maxNodeModuleJsDepth": 0,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "archive"]
}
